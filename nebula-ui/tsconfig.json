{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "~/*": ["./src/*"],
      "@": ["./src"],
      "@apps": ["./src/apps"],
      "@apps/*": ["./src/apps/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@routes": ["./src/routes"],
      "@routes/*": ["./src/routes/*"]
    }
  },
  "include": ["src"]
}
